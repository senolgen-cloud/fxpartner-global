# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Channel/group the bot posts to, e.g. @fxpartnerglobal or a numeric chat id
TELEGRAM_CHAT_ID=

# DeepL (free tier: https://www.deepl.com/pro-api) — used for faithful
# EN->TR translation of news headlines, never for "creative" rewriting
DEEPL_API_KEY=

# Upstash Redis (Vercel Marketplace > Storage > Redis) — tracks which
# news items have already been posted so we never repeat one
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random string you choose yourself — Vercel Cron sends it back as a
# Bearer token so only real cron triggers (not the public internet) can
# hit /api/cron/*. Generate one with: openssl rand -hex 32
CRON_SECRET=

# Production site URL, used to build the chart image URL Telegram fetches
NEXT_PUBLIC_SITE_URL=https://fxpartner.global
